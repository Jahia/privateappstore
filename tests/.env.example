JAHIA_VERSION=${JAHIA_VERSION:-LATEST}
JAHIA_IMAGE=${JAHIA_IMAGE:-ghcr.io/jahia/jahia-ee-dev:8-SNAPSHOT}
TESTS_IMAGE=${TESTS_IMAGE:-jahia/privateappstore:latest}
MODULE_ID=${MODULE_ID:-privateappstore}
MANIFEST=${MANIFEST:-provisioning-manifest-snapshot.yml}
JAHIA_URL=${JAHIA_URL:-http://jahia:8080}
SUPER_USER_PASSWORD=${SUPER_USER_PASSWORD:-root1234}
JAHIA_LICENSE=${JAHIA_LICENSE:-""}
JAHIA_HOST=${JAHIA_HOST:-jahia}
PRIVATEAPPSTORE_VERSION=${PRIVATEAPPSTORE_VERSION:-5.0.1-SNAPSHOT}
STORE_TEMPLATE_VERSION=${STORE_TEMPLATE_VERSION:-5.0.1-SNAPSHOT}
NEXUS_URL=${NEXUS_URL:-http://nexus:8081}
NEXUS_USERNAME=${NEXUS_USERNAME:-admin}
NEXUS_PASSWORD=${NEXUS_PASSWORD:-admin123}
